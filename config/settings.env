# ML Monitoring System Configuration

# Database
DATABASE_URL=postgresql://ml_monitor:password@localhost/ml_monitoring

# Monitoring
DRIFT_CHECK_INTERVAL_MINUTES=60
PERFORMANCE_CHECK_INTERVAL_MINUTES=30
DRIFT_THRESHOLD=0.1
PERFORMANCE_DEGRADATION_THRESHOLD=0.05

# Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=alerts@company.com
EMAIL_PASSWORD=your_password
FROM_EMAIL=alerts@company.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Model Storage
MODEL_STORAGE_PATH=models/
TRAINING_DATA_PATH=data/training/
INFERENCE_DATA_PATH=data/inference/

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ml_monitoring.log