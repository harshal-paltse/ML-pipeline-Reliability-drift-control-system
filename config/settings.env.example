# ─────────────────────────────────────────────────────────────────────────────
# ML Monitoring System — Runtime Configuration Template
# Copy to config/settings.env and fill in real values.
# NEVER commit config/settings.env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev:
DATABASE_URL=sqlite:///./ml_monitoring.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# ── Monitoring Schedule ───────────────────────────────────────────────────────
DRIFT_CHECK_INTERVAL_MINUTES=60
PERFORMANCE_CHECK_INTERVAL_MINUTES=30
MONITORING_INTERVAL_MINUTES=5

# ── Drift & Performance Thresholds ───────────────────────────────────────────
DRIFT_THRESHOLD=0.1
PERFORMANCE_DEGRADATION_THRESHOLD=0.05

# ── Email Alerts ─────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
FROM_EMAIL=
ALERT_RECIPIENTS=

# ── Slack Alerts ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Storage Paths ────────────────────────────────────────────────────────────
MODEL_STORAGE_PATH=models/
TRAINING_DATA_PATH=data/training/
INFERENCE_DATA_PATH=data/inference/

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
