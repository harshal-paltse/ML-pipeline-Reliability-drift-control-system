# ─────────────────────────────────────────────────────────────────────────────
# ML Pipeline Reliability & Drift Control System — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── Backend Server ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local development)
DATABASE_URL=sqlite:///./ml_monitoring.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/ml_monitoring

# ── Authentication & Security ─────────────────────────────────────────────────
# IMPORTANT: Generate a strong secret key before deploying to production.
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deploying-to-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── Frontend ──────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8001

# ── Firebase (optional — for authentication UI) ───────────────────────────────
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_DATABASE_URL=

# ── Alerts ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
FROM_EMAIL=
# Comma-separated list of email addresses to receive critical alerts
ALERT_RECIPIENTS=you@example.com,team@example.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── MLflow (optional — for experiment tracking) ───────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Data Paths ────────────────────────────────────────────────────────────────
REFERENCE_DATA_PATH=data/training/reference.parquet
INFERENCE_DATA_PATH=data/inference/current.parquet
